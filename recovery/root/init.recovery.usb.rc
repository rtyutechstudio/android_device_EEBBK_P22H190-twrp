# =========================================================
# TWRP USB CONFIGFS FULL STABLE (ADB / MTP / SIDELoad / FASTBOOTD)
# Fix: FUNCTIONFS timeout + 5s disconnect loop (Unisoc/Qcom fix style)
# =========================================================


# =========================================================
# 0. GLOBAL INIT
# =========================================================
on init
    setprop sys.usb.udc none

    mount configfs none /config


# =========================================================
# 1. CREATE GADGET BASE
# =========================================================
on init
    mkdir /config/usb_gadget/g1 0770 root root

    write /config/usb_gadget/g1/idVendor 0x18D1
    write /config/usb_gadget/g1/idProduct 0x4EE7

    mkdir /config/usb_gadget/g1/strings/0x409
    write /config/usb_gadget/g1/strings/0x409/manufacturer "TWRP"
    write /config/usb_gadget/g1/strings/0x409/product "TWRP Recovery"
    write /config/usb_gadget/g1/strings/0x409/serialnumber "0001"

    mkdir /config/usb_gadget/g1/configs/b.1
    mkdir /config/usb_gadget/g1/configs/b.1/strings/0x409
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "ADB/MTP"
    write /config/usb_gadget/g1/configs/b.1/MaxPower 120


# =========================================================
# 2. FUNCTIONS (ADB + MTP)
# =========================================================
on init
    mkdir /config/usb_gadget/g1/functions/ffs.adb
    mkdir /config/usb_gadget/g1/functions/mtp.gs0

    mkdir /dev/usb-ffs/adb 0770 shell shell
    mount functionfs adb /dev/usb-ffs/adb


# =========================================================
# 3. CLEAN HELPER (SAFE RESET)
# =========================================================
on property:sys.usb.reset=1
    write /config/usb_gadget/g1/UDC ""

    rm /config/usb_gadget/g1/configs/b.1/f1 || true
    rm /config/usb_gadget/g1/configs/b.1/f2 || true

    setprop sys.usb.ffs.ready 0


# =========================================================
# 4. ADB MODE (FIXED)
# =========================================================
on property:sys.usb.config=adb

    write /config/usb_gadget/g1/UDC ""

    rm /config/usb_gadget/g1/configs/b.1/f1 || true
    rm /config/usb_gadget/g1/configs/b.1/f2 || true

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1

    setprop sys.usb.ffs.ready 1


# =========================================================
# 5. MTP MODE
# =========================================================
on property:sys.usb.config=mtp

    write /config/usb_gadget/g1/UDC ""

    rm /config/usb_gadget/g1/configs/b.1/f1 || true
    rm /config/usb_gadget/g1/configs/b.1/f2 || true

    symlink /config/usb_gadget/g1/functions/mtp.gs0 /config/usb_gadget/g1/configs/b.1/f1

    write /config/usb_gadget/g1/UDC ${sys.usb.controller}


# =========================================================
# 6. ADB + MTP MODE (TWRP DEFAULT)
# =========================================================
on property:sys.usb.config=mtp,adb

    write /config/usb_gadget/g1/UDC ""

    rm /config/usb_gadget/g1/configs/b.1/f1 || true
    rm /config/usb_gadget/g1/configs/b.1/f2 || true

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1
    symlink /config/usb_gadget/g1/functions/mtp.gs0 /config/usb_gadget/g1/configs/b.1/f2

    setprop sys.usb.ffs.ready 1


# =========================================================
# 7. SIDeload MODE (ADB ONLY)
# =========================================================
on property:sys.usb.config=sideload

    write /config/usb_gadget/g1/UDC ""

    rm /config/usb_gadget/g1/configs/b.1/f1 || true

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1

    setprop sys.usb.ffs.ready 1


# =========================================================
# 8. FASTBOOTD MODE (NO CONFIGFS, SEPARATE STACK)
# =========================================================
on property:sys.usb.config=fastboot

    stop adbd

    write /config/usb_gadget/g1/UDC ""

    setprop sys.usb.ffs.ready 0

    start fastbootd


# =========================================================
# 9. SAFE BIND (CRITICAL FIX FOR 5s DISCONNECT)
# =========================================================
on property:sys.usb.ffs.ready=1

    # WAITED STATE → NOW SAFE TO BIND UDC
    write /config/usb_gadget/g1/UDC ${sys.usb.controller}

    # START ADB ONLY AFTER FUNCTIONFS IS READY
    start adbd