# =========================================================
# SPRD / UMS512 RECOVERY USB CONFIGFS (STABLE VERSION)
# =========================================================

on init
    # mount configfs early
    mount configfs none /config

    # default state
    setprop sys.usb.config none
    setprop sys.usb.state none

    # start adbd early (recovery safe)
    start adbd


# =========================================================
# WAIT UDC (CRITICAL)
# =========================================================
on boot
    wait /sys/class/udc/

    # DO NOT bind here blindly, wait usb mode trigger
    setprop sys.usb.ready 1


# =========================================================
# CREATE GADGET BASE
# =========================================================
on fs
    mkdir /config/usb_gadget/g1

    write /config/usb_gadget/g1/idVendor 0x1782
    write /config/usb_gadget/g1/idProduct 0x4D00

    mkdir /config/usb_gadget/g1/strings/0x409
    write /config/usb_gadget/g1/strings/0x409/manufacturer "Unisoc"
    write /config/usb_gadget/g1/strings/0x409/product "UMS512 Recovery"
    write /config/usb_gadget/g1/strings/0x409/serialnumber ${ro.serialno}


# =========================================================
# ADB FUNCTION (PRIMARY MODE)
# =========================================================
on property:sys.usb.config=adb

    mkdir /config/usb_gadget/g1/functions/ffs.adb

    mkdir /config/usb_gadget/g1/configs/b.1
    mkdir /config/usb_gadget/g1/configs/b.1/strings/0x409
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "adb"

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1

    # bind UDC (ONLY HERE)
    write /config/usb_gadget/g1/UDC musb-hdrc

    start adbd
    setprop sys.usb.state adb


# =========================================================
# SIDELOAD MODE (ADB)
# =========================================================
on property:sys.usb.config=sideload

    mkdir /config/usb_gadget/g1/functions/ffs.adb

    mkdir /config/usb_gadget/g1/configs/b.1
    mkdir /config/usb_gadget/g1/configs/b.1/strings/0x409
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "sideload"

    symlink /config/usb_gadget/g1/functions/ffs.adb /config/usb_gadget/g1/configs/b.1/f1

    write /config/usb_gadget/g1/UDC musb-hdrc

    start adbd
    setprop sys.usb.state sideload


# =========================================================
# FASTBOOTD MODE (userspace fastboot)
# =========================================================
on property:sys.usb.config=fastboot

    # change USB identity to fastboot
    write /config/usb_gadget/g1/idVendor 0x18d1
    write /config/usb_gadget/g1/idProduct 0x4EE0

    mkdir /config/usb_gadget/g1/configs/b.1
    mkdir /config/usb_gadget/g1/configs/b.1/strings/0x409
    write /config/usb_gadget/g1/configs/b.1/strings/0x409/configuration "fastboot"

    write /config/usb_gadget/g1/UDC musb-hdrc

    setprop sys.usb.state fastboot


# =========================================================
# USB OFF
# =========================================================
on property:sys.usb.config=none

    stop adbd

    # unbind safely
    write /config/usb_gadget/g1/UDC ""

    setprop sys.usb.state none